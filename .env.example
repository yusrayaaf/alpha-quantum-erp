# ═══════════════════════════════════════════════════════════════════════════════
#  Alpha Quantum ERP v18 — Environment Variables
#  SETUP: cp .env.example .env  then fill in your values
#  WARNING: NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# NeonDB → https://console.neon.tech → New Project → Connection String (free, no CC)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT secret (auto-generated by SETUP.sh)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-48+-char-hex-secret

# ── CREATOR ACCOUNT ──────────────────────────────────────────────────────────
VITE_CREATOR_USERNAME=maynulshaon
CREATOR_PASSWORD=Creator@2025!
CREATOR_EMAIL=erp@alpha-01.info
CREATOR_FULL_NAME=Mohammad Maynul Hasan Shaon

# ── EMAIL (IONOS SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.ionos.com
SMTP_PORT=587
SMTP_USER=erp@alpha-01.info
SMTP_PASS=your_ionos_email_password
SMTP_FROM=Alpha Quantum ERP <erp@alpha-01.info>
SMTP_REPLY_TO=reply@alpha-01.info

# ── CLOUDFLARE R2 (optional — for file uploads, free 10GB/month) ─────────────
# → https://dash.cloudflare.com → R2 → Create Bucket + API Token
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_ACCESS_KEY_ID=your_r2_access_key_id
CF_SECRET_ACCESS_KEY=your_r2_secret_key
CF_R2_BUCKET=alpha-erp-uploads
CF_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── IMGBB (alternative to R2 for images, 100% free no CC) ────────────────────
# → https://api.imgbb.com
IMGBB_API_KEY=your_imgbb_api_key

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
